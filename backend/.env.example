# Backend configuration (env-driven). Copy to .env for the uvicorn/alembic fallback.
# The repo-wide .env.example is consolidated in #7; these are the backend's vars.

# SQLAlchemy URL for the sync psycopg driver.
DATABASE_URL=postgresql+psycopg://electrobard:electrobard@localhost:5432/electrobard

# Root directory for local-disk audio storage (save/get/delete by key).
STORAGE_ROOT=./var/storage

# API listen port.
PORT=8000

# Used only by the test harness; falls back to DATABASE_URL if unset.
# TEST_DATABASE_URL=postgresql+psycopg://electrobard:electrobard@localhost:5432/electrobard_test
