{
  "components": {
    "schemas": {
      "SoundRead": {
        "description": "A single library entry as returned by the API.",
        "properties": {
          "id": {
            "format": "uuid",
            "title": "Id",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "name"
        ],
        "title": "SoundRead",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "ElectroBard API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/sounds": {
      "get": {
        "description": "List the current user's sounds. Empty until the Sound model arrives in M1.",
        "operationId": "list_sounds",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/SoundRead"
                  },
                  "title": "Response List Sounds",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "List Sounds",
        "tags": [
          "sounds"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Liveness: the process is up and serving.",
        "operationId": "health",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health"
      }
    },
    "/health/db": {
      "get": {
        "description": "Readiness: the database is reachable.",
        "operationId": "health_db",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "title": "Response Health Db",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health Db"
      }
    }
  }
}
