# ElectroBard — environment template. Copy to `.env` and adjust.
# No secrets at launch: no auth, local-disk storage (ADR-0001, ADR-0002).

# --- Backend (app/settings.py) ---

# SQLAlchemy URL for the sync psycopg driver.
DATABASE_URL=postgresql+psycopg://electrobard:electrobard@localhost:5432/electrobard

# Postgres the test suite connects to (falls back to DATABASE_URL). Tests roll back
# per-test, but point this at a throwaway DB in CI regardless.
TEST_DATABASE_URL=postgresql+psycopg://electrobard:electrobard@localhost:5432/electrobard

# Root directory for the local-disk storage interface (save/get/delete by key).
STORAGE_ROOT=./var/storage

# Port the API listens on.
PORT=8000

# --- Frontend (Vite) ---

# Where the dev server proxies `/api` (vite.config.ts). The generated client uses
# same-origin relative URLs, so the browser never needs the backend's address — only
# this server-side proxy does. In compose it's the `backend` service; standalone it
# defaults to the local backend (below is the standalone value).
VITE_API_PROXY_TARGET=http://localhost:8000

# --- Docker compose overrides (compose.yaml; all optional, defaults shown) ---
# The compose stack builds DATABASE_URL from these and points the backend at the `db`
# service, so you don't set DATABASE_URL for the Docker path — only for the fallback.

# Postgres credentials/name for the `db` service.
POSTGRES_USER=electrobard
POSTGRES_PASSWORD=electrobard
POSTGRES_DB=electrobard

# Published host ports (container ports are fixed).
DB_PORT=5432        # -> db:5432
# PORT (above) publishes the backend; VITE_PORT publishes the frontend dev server.
VITE_PORT=5173
